  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e7ce9d381534412d9c920d8fd1619c43, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LevelIntroOverlay
  titleText: How to Play
  bodyText: "Your job is to bring the flock to safety before time runs out.\nSheep
    won\u2019t follow commands directly as they move on their own, but they will
    move away from sheepdogs. Use your dogs to guide the flock from behind, cut them
    off from the sides, and keep them moving toward the goal.\n\nPress a sheepdog\u2019s
    number to select it, then click where you want it to run.\nPress the same number
    again to deselect.\n\nStay alert. A wolf is stalking the pasture, waiting for
    sheep that fall behind or drift too far from the flock. Keep the sheep grouped
    together and away from danger, or the wolf will pick them off. Sheepdogs can
    be used to pressure and force the wolf away.\n\nSave enough sheep before the
    timer ends to win.\nSave 80% for 1 star, 90% for 2 stars, and every sheep for
    3 stars.\nIf too many are lost or you run out of time, you lose."
  continueText: Click or press Space to start
  panelWidth: 1120
  panelHeight: 700
  panelOffsetX: 0
  panelOffsetY: -70
  titleTop: 18
  bodyTop: 78
  bodyHeight: 470
  continueBottom: -40
  pauseWhileVisible: 1
  backdropColor: {r: 0, g: 0, b: 0, a: 0.5}
  panelColor: {r: 0.13, g: 0.11, b: 0.08, a: 0.94}
  titleColor: {r: 1, g: 1, b: 1, a: 1}
  bodyColor: {r: 1, g: 1, b: 1, a: 1}
  continueColor: {r: 1, g: 0.95, b: 0.82, a: 1}
